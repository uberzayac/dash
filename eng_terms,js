const PRO_ENGLISH_TERMS = [
  { word: "bleed", translation: "вылет", pronunciation: "/bliːd/", definition: "Вылет за край обрезки макета; зона, которая уходит под нож", example: "Hey, before you send this to print, make sure the background image goes all the way to the bleed, otherwise we’ll get those ugly white edges.", example_ru: "Эй, перед отправкой в печать убедись, что фон заходит на bleed, а то получатся те самые уродливые белые полоски по краям.", category: "вёрстка" },

